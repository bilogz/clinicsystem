# Supabase-only configuration
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
API_PORT=3001
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174
SUPABASE_PROJECT_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=replace-with-an-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-a-service-role-key

# Vite and local proxy defaults used by the current app.
VITE_DEV_PROXY_TARGET=http://localhost
VITE_DEV_BACKEND_ROOT=/Clinic%20System
# Use an absolute path (/api/...) or full https:// URL. Do not use bare names like "login" — from /admin/login the browser resolves those to the login page and POST returns 405.
VITE_BACKEND_API_BASE_URL=
VITE_ADMIN_AUTH_API_URL=
VITE_CASHIER_INTEGRATION_API_URL=

# Cashier integration settings.
CASHIER_INTEGRATION_ENABLED=true
CASHIER_SYSTEM_BASE_URL=supabase://internal
CASHIER_SYNC_MODE=auto
CASHIER_SYSTEM_INBOUND_PATH=/api/integrations/cashier/payment-status
CASHIER_SHARED_TOKEN=
# Shared secret for department bridges (Prefect → Clinic incident POST, etc.)
# The clinic does NOT call Prefect. Prefect's hub POSTs to /api/integrations/prefect/incident-reports with X-Integration-Token.
# Use the same value in Prefect (CLINIC_DEPARTMENT_INTEGRATION_TOKEN or DEPARTMENT_INTEGRATION_SHARED_TOKEN).
# If Prefect runs on Netlify, CLINIC_PREFECT_BRIDGE_URL must be a public HTTPS URL to this API—not localhost.
DEPARTMENT_INTEGRATION_SHARED_TOKEN=
