# Supabase-only configuration
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_PROJECT_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=replace-with-an-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-a-service-role-key

# Vite and local proxy defaults used by the current app.
VITE_DEV_PROXY_TARGET=http://localhost
VITE_DEV_BACKEND_ROOT=/Clinic%20System
VITE_BACKEND_API_BASE_URL=
VITE_CASHIER_INTEGRATION_API_URL=

# Cashier integration settings.
CASHIER_INTEGRATION_ENABLED=true
CASHIER_SYSTEM_BASE_URL=supabase://internal
CASHIER_SYNC_MODE=auto
CASHIER_SYSTEM_INBOUND_PATH=/api/integrations/cashier/payment-status
